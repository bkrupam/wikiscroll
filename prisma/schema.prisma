generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Card {
  id           String        @id @default(cuid())
  hookText     String
  wikiTitle    String
  wikiUrl      String
  categories   String        // JSON array of TopicNode ids — the [d0, d1, d2] path
  gradientId   Int           // 1–6
  hookScore    Float
  tier         Int           // 1=seed, 2=broad, 3=personalized
  served       Boolean       @default(false)
  createdAt    DateTime      @default(now())

  interactions Interaction[]
}

model Interaction {
  id           String   @id @default(cuid())
  cardId       String
  card         Card     @relation(fields: [cardId], references: [id])
  type         String   // "LIKE" | "DWELL" | "SKIP" | "SAVE"
  dwellSeconds Float?
  createdAt    DateTime @default(now())
}

/// Hierarchical topic taxonomy. depth 0 = root, 1 = subtopic, 2 = sub-subtopic.
model TopicNode {
  id        String       @id @default(cuid())
  name      String       @unique
  parentId  String?
  parent    TopicNode?   @relation("Children", fields: [parentId], references: [id])
  children  TopicNode[]  @relation("Children")
  depth     Int
  createdAt DateTime     @default(now())

  arm       CategoryArm?
}

model CategoryArm {
  nodeId     String    @id
  node       TopicNode @relation(fields: [nodeId], references: [id])
  alpha      Float     @default(1.0)
  beta       Float     @default(1.0)
  totalPulls Int       @default(0)
  updatedAt  DateTime  @updatedAt
}
