generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Anonymous user identified by a cookie. We never collect anything beyond the id.
model User {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  /// Last time the daily α/β decay job ran for this user.
  lastDecayAt DateTime @default(now())

  interactions Interaction[]
  arms         CategoryArm[]
  saves        SavedCard[]
}

model Card {
  id           String        @id @default(cuid())
  hookText     String
  wikiTitle    String        @unique
  wikiUrl      String
  categories   String        // JSON array of TopicNode ids — the [d0, d1, d2] path
  gradientId   Int
  hookScore    Float
  tier         Int
  served       Boolean       @default(false)
  createdAt    DateTime      @default(now())

  interactions Interaction[]
  saves        SavedCard[]
}

model Interaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  cardId       String
  card         Card     @relation(fields: [cardId], references: [id])
  type         String   // "LIKE" | "DWELL" | "SKIP" | "SAVE"
  dwellSeconds Float?
  /// JSON array of leaf nodeIds touched by this interaction — used for
  /// skip-streak detection without re-reading the card on every behavior write.
  leafNodeId   String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

/// Hierarchical topic taxonomy. depth 0 = root, 1 = subtopic, 2 = sub-subtopic.
model TopicNode {
  id        String       @id @default(cuid())
  name      String       @unique
  parentId  String?
  parent    TopicNode?   @relation("Children", fields: [parentId], references: [id])
  children  TopicNode[]  @relation("Children")
  depth     Int
  createdAt DateTime     @default(now())

  arms      CategoryArm[]
}

/// One bandit arm per (user, topic). Composite PK.
model CategoryArm {
  userId     String
  nodeId     String
  user       User      @relation(fields: [userId], references: [id])
  node       TopicNode @relation(fields: [nodeId], references: [id])
  alpha      Float     @default(1.0)
  beta       Float     @default(1.0)
  totalPulls Int       @default(0)
  updatedAt  DateTime  @updatedAt

  @@id([userId, nodeId])
}

model SavedCard {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, cardId])
}
